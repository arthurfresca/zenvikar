{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@zenvikar/types": ["./packages/types/src"],
      "@zenvikar/types/*": ["./packages/types/src/*"],
      "@zenvikar/config": ["./packages/config/src"],
      "@zenvikar/config/*": ["./packages/config/src/*"],
      "@zenvikar/ui": ["./packages/ui/src"],
      "@zenvikar/ui/*": ["./packages/ui/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "out"]
}
