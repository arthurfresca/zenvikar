# =============================================================================
# Zenvikar Platform — Environment Variables
# Copy this file to .env and adjust values for your local setup.
# =============================================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://zenvikar:zenvikar@localhost:5432/zenvikar?sslmode=disable

# --- Cache (Redis) ---
REDIS_URL=localhost:6379

# --- API Server ---
PORT=8080
# Set to "production" to disable Swagger docs routes (/swagger, /swagger/openapi.yaml)
APP_ENV=development
JWT_SECRET=dev-only-change-me
JWT_TTL_MINUTES=120

# --- Domain ---
BASE_DOMAIN=zenvikar.localhost

# --- CORS ---
# Comma-separated list of allowed origins. Use "*" to allow all.
ALLOWED_ORIGINS=http://zenvikar.localhost,http://manage.zenvikar.localhost,http://admin.zenvikar.localhost

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# --- Frontend (booking-web) ---
NEXT_PUBLIC_BASE_DOMAIN=zenvikar.localhost
API_INTERNAL_URL=http://api:8080

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
